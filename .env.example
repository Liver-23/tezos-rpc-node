# Tezos RPC nodes — copy to .env and adjust
# cp .env.example .env

# Official Octez image (https://hub.docker.com/r/tezos/tezos)
OCTEZ_IMAGE=tezos/tezos-bare:latest

# --- Mainnet (started by default: docker compose up -d) -----------------------

CONTAINER_NAME=tezos-mainnet-rpc
MAINNET_CHAIN_ID=NetXdQprcVkpaWU

# Host bind addresses (RPC localhost-only by default)
RPC_BIND=127.0.0.1
RPC_PORT=8732
P2P_BIND=0.0.0.0
P2P_PORT=9732

# full: default; supports TEZOSSpec pruning verification (28k block window)
# rolling: less disk, faster sync; may fail Lava "pruning" verification for old blocks
# archive: full historical state; use docker-compose.archive.yml + archive snapshot
HISTORY_MODE=full

CONNECTIONS=50

# Snapshot file on host (used by scripts/import-snapshot.sh mainnet)
SNAPSHOT_FILE=./snapshots/mainnet.snapshot

# Rolling snapshot (recommended for first sync)
SNAPSHOT_URL=https://snapshots.tzinit.org/mainnet/rolling

# Full snapshot (use when HISTORY_MODE=full)
# SNAPSHOT_URL=https://snapshots.tzinit.org/mainnet/full

# Archive snapshot (use with docker-compose.archive.yml)
# SNAPSHOT_URL_ARCHIVE=https://snapshots.tzinit.org/mainnet/archive

# --- Testnet / Shadownet (--profile testnet) ----------------------------------

# Enable testnet whenever you run docker compose (optional):
# COMPOSE_PROFILES=testnet

TESTNET_CONTAINER_NAME=tezos-testnet-rpc
TESTNET_CHAIN_ID=NetXsqzbfFenSTS
TESTNET_NETWORK=https://teztnets.com/shadownet

# Distinct host ports so mainnet and testnet can run together
TESTNET_RPC_BIND=127.0.0.1
TESTNET_RPC_PORT=8733
TESTNET_P2P_BIND=0.0.0.0
TESTNET_P2P_PORT=9733

TESTNET_HISTORY_MODE=rolling
TESTNET_CONNECTIONS=50

TESTNET_SNAPSHOT_FILE=./snapshots/testnet.snapshot
TESTNET_SNAPSHOT_URL=https://snapshots.tzinit.org/shadownet/rolling
TESTNET_RPC_URL=http://127.0.0.1:8733

# --- Shared -------------------------------------------------------------------

# aria2c download tuning (scripts/import-snapshot.sh)
ARIA2_CONNECTIONS=16
ARIA2_SPLIT=16

# Base URL for scripts/verify-spec-apis.sh (mainnet; from host)
RPC_URL=http://127.0.0.1:8732
# Per-request timeout in seconds (long-poll /monitor/* APIs are skipped)
VERIFY_TIMEOUT=10
# VERIFY_INCLUDE_HANGING=1

# tezos/tezos-bare container user (default 1000:1000)
TEZOS_UID=1000
TEZOS_GID=1000
